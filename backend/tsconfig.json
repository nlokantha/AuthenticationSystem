{
    "include": ["src/**/*"],
    "exclude": ["node_modules","dist"],
    "compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],

		"allowJs": true,
		"checkJs": false,
		"noEmit": true,

		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true
	}
}